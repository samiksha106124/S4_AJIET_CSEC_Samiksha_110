import java.util.Scanner;
class main {
    public static void main(String[] args) {
    int last,num,rev=0;
    System.out.println("enter the value of n");
    Scanner s =new Scanner(System.in);
    int n=s.nextInt();
    num=n;
    while(n>0)
    {
        last=n%10;
        rev=rev*10+last;
        n=n/10;
    }
    System.out.println("rev="+rev);
    
    }
}
